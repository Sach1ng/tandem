# dependencies
node_modules/
.pnp.*

# build output
dist/
out/
*.tsbuildinfo

# secrets & local config
.env
.env.local
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example
config.json
**/config.json
!config.default.json

# OAuth & API credentials (never commit)
**/gcp-oauth.keys.json
**/gcp-oauth*.json
**/*oauth*.keys.json
**/client_secret*.json
**/credentials.json
**/service-account*.json
**/tokens.json
**/.config/gws/
**/.config/google-drive-mcp/

# MCP local config (env may contain API keys / OAuth secrets)
.cursor/mcp.json
!.cursor/mcp.json.example

# runtime state (never commit) — chat sessions, dedupe sets, grants, logs
**/sessions.json
**/processed.json
**/open-threads.json
**/state/
*.log
logs/

# os / editor
.DS_Store
.idea/
*.swp

# packaged apps
apps/pip/release/
apps/pip/*.app

# pm-os npm bundle (generated by packages/pm-os/scripts/prepare.mjs)
packages/pm-os/brain/
packages/pm-os/AGENTS.md
packages/pm-os/AGENTS.installed.md
packages/pm-os/tasks.template.md

# pip screenshot scratch (visual context sent to the agent)
.tandem/

# cross-surface activity log (may contain user data — never commit)
**/memory/activity.md
