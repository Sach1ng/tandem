# dependencies
node_modules/
.pnp.*

# build output
dist/
out/
*.tsbuildinfo

# secrets & local config
.env
.env.local
**/.env
config.json
**/config.json
!config.default.json

# runtime state (never commit) — chat sessions, dedupe sets, grants, logs
**/sessions.json
**/processed.json
**/open-threads.json
**/state/
*.log
logs/

# os / editor
.DS_Store
.idea/
*.swp

# packaged apps
apps/clippy/release/
apps/clippy/*.app

# pm-os npm bundle (generated by packages/pm-os/scripts/prepare.mjs)
packages/pm-os/brain/
packages/pm-os/AGENTS.md
packages/pm-os/AGENTS.installed.md
packages/pm-os/tasks.template.md

# clippy screenshot scratch (visual context sent to the agent)
.tandem/

# cross-surface activity log (may contain user data — never commit)
**/memory/activity.md
