{
  "manifest_version": 3,
  "name": "Pip",
  "short_name": "Pip",
  "version": "0.1.0",
  "description": "Pip — your page-aware browser surface. Ask about whatever tab you're on, answered by the Cursor CLI against your PM OS workspace.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pip — ask about this page"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "contextMenus", "storage"],
  "host_permissions": ["http://127.0.0.1:8765/*"],
  "commands": {
    "summon-pip": {
      "suggested_key": {
        "default": "Ctrl+B",
        "mac": "Command+B"
      },
      "description": "Summon Pip on this page"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
