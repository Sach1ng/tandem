{
  "workspace": ".",
  "tasksFile": "tasks.example.md",
  "agent": "cursor-agent",
  "agentModel": "auto",
  "agentFlags": ["-p", "--trust", "--output-format", "text"],
  "panel": {
    "minW": 300,
    "minH": 56,
    "maxW": 520,
    "maxH": 220,
    "defaultW": 400,
    "defaultH": 58,
    "compactH": 58,
    "tallH": 156,
    "snipH": 172
  },
  "collapsed": {
    "w": 56,
    "h": 56
  },
  "placement": {
    "corner": "top-right",
    "margin": 16
  },
  "hotkey": {
    "snip": "Command+Shift+T",
    "autoAsk": false,
    "question": "What's on my screen? If there's an error, tell me how to fix it."
  },
  "nudge": {
    "enabled": true,
    "idleSeconds": 120,
    "cooldownSeconds": 600
  },
  "voice": {
    "enabled": false,
    "autoSend": true,
    "speakReplies": false
  }
}
