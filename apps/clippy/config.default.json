  "nudge": {
    "enabled": true,
    "idleSeconds": 120,
    "cooldownSeconds": 600
  },
  "voice": {
    "enabled": false,
    "autoSend": true,
    "speakReplies": false
  },
  "monitor": {
    "enabled": true,
    "port": 8791
  }
