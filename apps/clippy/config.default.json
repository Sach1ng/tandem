{
  "workspace": ".",
  "tasksFile": "tasks.example.md",
  "agent": "cursor-agent",
  "agentModel": "auto",
  "agentFlags": ["-p", "--trust", "--output-format", "text"],
  "panel": {
    "minW": 280,
    "minH": 160,
    "maxW": 340,
    "maxH": 420,
    "defaultW": 320,
    "defaultH": 360
  },
  "collapsed": {
    "w": 48,
    "h": 48
  },
  "hotkey": {
    "snip": "Command+Shift+T",
    "autoAsk": true,
    "question": "What's on my screen? If there's an error, tell me how to fix it."
  },
  "nudge": {
    "enabled": true,
    "idleSeconds": 120,
    "cooldownSeconds": 600
  },
  "voice": {
    "enabled": false,
    "autoSend": true,
    "speakReplies": false
  }
}
