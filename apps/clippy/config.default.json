{
  "workspace": ".",
  "tasksFile": "tasks.example.md",
  "agent": "cursor-agent",
  "agentModel": "auto",
  "agentFastModel": "composer-2.5-fast",
  "agentVisionModel": "composer-2.5-fast",
  "agentFlags": ["-p", "--trust", "--output-format", "text"],
  "panel": {
    "minW": 390,
    "minH": 73,
    "maxW": 676,
    "maxH": 520,
    "defaultW": 520,
    "defaultH": 75,
    "compactH": 75,
    "tallH": 148,
    "snipH": 240
  },
  "collapsed": {
    "w": 73,
    "h": 73
  },
  "placement": {
    "corner": "bottom-right",
    "margin": 16
  },
  "hotkey": {
    "snip": "Command+Shift+T",
