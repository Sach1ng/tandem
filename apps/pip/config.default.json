{
  "workspace": ".",
  "tasksFile": "tasks.example.md",
  "agent": "cursor-agent",
  "agentModel": "auto",
  "agentFastModel": "composer-2.5-fast",
  "agentVisionModel": "composer-2.5-fast",
  "models": ["composer-2.5-fast", "auto", "gpt-5", "sonnet-4.5"],
  "agentFlags": ["-p", "--trust", "--output-format", "text"],
  "panel": {
    "minW": 390,
    "minH": 116,
    "maxW": 676,
    "maxH": 540,
    "defaultW": 520,
    "defaultH": 118,
    "compactH": 118,
    "tallH": 196,
    "snipH": 280
  },
  "collapsed": {
    "w": 73,
    "h": 73
  },
  "placement": {
    "corner": "bottom-right",
    "margin": 16,
    "snapThreshold": 64
  },
  "peek": {
    "enabled": false,
    "idleSeconds": 45,
    "insetPct": 0.34
  },
  "hotkey": {
    "snip": "Command+Shift+T",
    "summon": "Command+Shift+Space",
    "hide": "Command+Shift+H",
    "voice": "Command+N",
    "autoAsk": false,
    "question": "What's on my screen? If there's an error, tell me how to fix it."
  },
  "personality": {
    "motion": true,
    "gaze": true,
    "greet": true,
    "celebrate": true,
    "sleepy": true,
    "sleepyIdleSeconds": 45
  },
  "nudge": {
    "enabled": true,
    "idleSeconds": 120,
    "cooldownSeconds": 600
  },
  "voice": {
    "enabled": false,
    "autoSend": true,
    "speakReplies": false
  },
  "monitor": {
    "enabled": true,
    "port": 8791
  },
  "ui": {
    "showInDock": false
  }
}
