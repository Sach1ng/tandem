{
  "name": "@tandem/pip",
  "version": "0.1.0",
  "description": "Pip — a frameless always-on-top AI coworker on your screen, backed by tasks.md, with ask/snip/groom/capture via the Cursor CLI.",
  "main": "dist/main.cjs",
  "bin": {
    "tandem-pip": "bin/pip.mjs"
  },
  "files": [
    "dist",
    "ui",
    "monitor",
    "bin",
    "config.default.json"
  ],
  "scripts": {
    "build": "node build.mjs",
    "start": "electron .",
    "dev": "npm run build && electron .",
    "prepublishOnly": "npm run build",
    "package": "npm run build && electron-packager . Pip --platform=darwin --arch=arm64 --out=release --overwrite"
  },
  "dependencies": {
    "@tandem/core": "0.1.0",
    "@tandem/engine": "0.1.0",
    "chokidar": "^4.0.0",
    "electron": "^35.0.0"
  },
  "devDependencies": {
    "electron-packager": "^17.1.2"
  },
  "engines": {
    "node": ">=20.6"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
