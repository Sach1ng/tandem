# --- Slack tokens (from api.slack.com/apps → your app) ---
# Bot User OAuth Token, starts with xoxb-
SLACK_BOT_TOKEN=xoxb-...
# App-Level Token with connections:write scope, starts with xapp-
SLACK_APP_TOKEN=xapp-...
# User OAuth Token, starts with xoxp- (only needed for the search.messages polling fallback)
SLACK_USER_TOKEN=xoxp-...

# --- Access control ---
# Comma-separated Slack member IDs allowed to assign tasks. EMPTY = anyone (NOT recommended:
# --force means cursor-agent can run shell on this machine). Find your ID: profile → ⋮ → Copy member ID.
ALLOWED_USERS=U0123456789

# --- Engine (Cursor CLI) ---
# Working directory the agent runs in. Defaults to the Tandem repo root (AGENTS.md + PM OS submodule).
CURSOR_WORKDIR=
CURSOR_BIN=cursor-agent
# e.g. gpt-5, sonnet-4, or auto to let Cursor pick.
CURSOR_MODEL=auto
# Per-task hard timeout (ms).
MAX_RUNTIME_MS=600000
# How long an `open thread` grant lasts for non-owners (ms). Default 20h.
OPEN_THREAD_TTL_MS=72000000
