{
  "display_information": {
    "name": "Pip",
    "description": "Your team's AI coworker in Slack — tag @Pip in any channel. Powered by the Cursor CLI and PM OS.",
    "background_color": "#242428",
    "long_description": "Pip is your ambient AI coworker in Slack. Mention @Pip or DM it to run tasks against your PM OS workspace. Same Pip you get on desktop and in the browser."
  },
  "features": {
    "bot_user": {
      "display_name": "Pip",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "user": ["search:read", "search:read.public"],
      "bot": [
        "channels:history",
        "channels:join",
        "channels:read",
        "chat:write",
        "chat:write.public",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "mpim:read",
        "mpim:write",
        "users:read",
        "team:read",
        "links:read"
      ]
    }
  },
  "settings": {
    "socket_mode_enabled": true,
    "interactivity": {
      "is_enabled": true
    },
    "event_subscriptions": {
      "bot_events": ["message.channels", "message.groups", "message.im", "message.mpim"]
    }
  }
}
