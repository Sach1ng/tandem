    "@tandem/engine": "0.1.0",
    "@tandem/pm-os": "0.1.0"
  },
  "optionalDependencies": {
    "@tandem/pip": "0.1.0",
    "@tandem/slack": "0.1.0"
  },
  "engines": {
    "node": ">=20.6"
  },
  "license": "MIT",
  "publishConfig": {
