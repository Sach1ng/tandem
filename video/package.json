{
  "name": "tandem-launch-video",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion project for the Tandem / Pip launch + demo video.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "remotion studio",
    "studio": "remotion studio",
    "render": "remotion render LaunchVideo out/tandem-launch.mp4",
    "render:square": "remotion render LaunchVideoSquare out/tandem-launch-square.mp4",
    "render:vertical": "remotion render LaunchVideoVertical out/tandem-launch-vertical.mp4",
    "still": "remotion still LaunchVideo out/poster.png --frame=60",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.7.0"
  }
}
