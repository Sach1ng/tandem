    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html,
      body {
        margin: 0;
        width: 1920px;
        height: 1080px;
        overflow: hidden;
        background: #07080c;
        font-family: Inter, system-ui, sans-serif;
        color: #f4f5f7;
      }
      #root {
        position: relative;
        width: 1920px;
        height: 1080px;
        overflow: hidden;
      }
      .ground {
        position: absolute;
        inset: 0;
        background: radial-gradient(
            120% 80% at 50% 0%,
            #141824 0%,
            #07080c 55%,
            #05060a 100%
          ),
          #07080c;
      }
      .vignette {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: radial-gradient(
          ellipse at center,
          transparent 40%,
          rgba(0, 0, 0, 0.55) 100%
        );
        z-index: 5;
      }
      video.demo {
        position: absolute;
        inset: 0;
        width: 1920px;
        height: 1080px;
        object-fit: cover;
        z-index: 1;
        transform-origin: 50% 45%;
      }
      .glass {
        position: absolute;
        z-index: 10;
        background: linear-gradient(
          145deg,
          rgba(255, 255, 255, 0.16),
          rgba(255, 255, 255, 0.05)
