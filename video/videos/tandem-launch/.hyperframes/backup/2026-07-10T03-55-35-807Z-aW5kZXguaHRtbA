      const scatterTimes = [4.45, 5.5, 6.7, 8.0, 9.3];
      scatterItems.forEach((id, i) => {
        const t = scatterTimes[i];
        const hold = (scatterTimes[i + 1] || 12.3) - t;
        tl.fromTo(
          id,
          { opacity: 0, y: 18 },
          { opacity: 1, y: 0, duration: 0.4, ease: "power3.out" },
          t,
        );
        // Active: hide dot, show spinning ring, open chevron + desc
        tl.to(`${id} .mark .dot`, { opacity: 0, duration: 0.15 }, t);
        tl.to(`${id} .mark .spin`, { opacity: 1, duration: 0.15 }, t);
        tl.fromTo(
          `${id} .mark .spin`,
          { rotate: 0 },
          { rotate: 360 * Math.max(1, Math.round(hold / 0.9)), duration: hold, ease: "none" },
          t,
        );
        tl.to(`${id} .chev`, { rotate: 180, color: "rgba(255,255,255,0.75)", duration: 0.25 }, t);
        tl.to(`${id} .desc`, { maxHeight: 80, opacity: 1, duration: 0.35, ease: "power2.out" }, t + 0.05);
        // Collapse previous
        if (i > 0) {
          const prev = scatterItems[i - 1];
          tl.to(`${prev} .mark .spin`, { opacity: 0, duration: 0.15 }, t);
          tl.to(`${prev} .mark .dot`, { opacity: 1, duration: 0.15 }, t);
          tl.to(`${prev} .chev`, { rotate: 0, color: "rgba(255,255,255,0.45)", duration: 0.2 }, t);
          tl.to(`${prev} .desc`, { maxHeight: 0, opacity: 0, duration: 0.25 }, t);
        }
      });

      tl.fromTo(
        "#still-cursor",
        { opacity: 0, scale: 1.12 },
        { opacity: 1, scale: 1, duration: 0.45, ease: "power2.out" },
        12.5,
      );

      tl.fromTo("#slack-demo", { scale: 1 }, { scale: 1.0599607843137255, duration: 8.994117647058822, ease: "none" }, 22);
      tl.fromTo("#desktop-demo", { scale: 1 }, { scale: 1.0381579350490195, duration: 3.270680147058826, ease: "power1.inOut" }, 34);
      tl.fromTo(
        "#browser-demo",
        { scale: 1.04, xPercent: -1 },
        { scale: 1.12, xPercent: 1.5, duration: 10, ease: "none" },
        46,
      );

      tl.fromTo(
        "#face-slot",
        { opacity: 0, scale: 0.85, y: 24 },
        { opacity: 1, scale: 1, y: 0, duration: 0.8, ease: "power3.out" },
        0.4,
      );

      tl.fromTo("#slack-demo-split", { scale: 1.0599607843137255 }, { scale: 1.08, duration: 3.0058823529411782, ease: "none" }, 30.99411764705882);

      tl.fromTo("#desktop-demo-split", { scale: 1.0381579350490195 }, { scale: 1.14, duration: 8.729319852941174, ease: "power1.inOut" }, 37.270680147058826);

      tl.fromTo("__unresolved__", { opacity: 0 }, { opacity: 1, duration: 0.55, ease: "power3.out" }, 0);

      tl.fromTo("__unresolved__", { y: 28 }, { y: 0, duration: 0.55, ease: "power3.out" }, 0);

      tl.fromTo("__unresolved__", { scale: 0.96 }, { scale: 1, duration: 0.55, ease: "power3.out" }, 0);

      window.__timelines["main"] = tl;
    </script>
