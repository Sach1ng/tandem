        bottom: auto;
        max-width: 860px;
        background: linear-gradient(
          145deg,
          rgba(8, 10, 16, 0.72),
          rgba(8, 10, 16, 0.45)
        );
      }
      .center-card {
        left: 160px;
        right: 160px;
        top: 220px;
        text-align: left;
        max-width: 1280px;
        margin: 0 auto;
      }
      /* F3 — PIP intro + revolving surfaces */
      #f3.center-card {
        top: 160px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }
      .pip-intro-row {
        display: flex;
        align-items: center;
        gap: 28px;
        margin-bottom: 8px;
      }
      /* Real Pip buddy from apps/pip/ui — scaled for film */
      .pip-orb {
        --pip-deep: #161618;
        --pip-mid: #242428;
        --pip-light: #323238;
        --pip-warm: #c4a06a;
        --pip-warm-soft: #dcc9a8;
        --pip-warm-deep: #7a6248;
        --pip-warm-glow: rgba(196, 160, 106, 0.28);
        --pip-warm-mist: rgba(196, 160, 106, 0.08);
        position: relative;
        width: 128px;
        height: 128px;
        flex-shrink: 0;
        border-radius: 50%;
        background:
          radial-gradient(circle at 32% 24%, rgba(255, 255, 255, 0.06) 0%, transparent 46%),
          linear-gradient(155deg, var(--pip-light) 0%, var(--pip-mid) 48%, var(--pip-deep) 100%);
        box-shadow:
          0 12px 40px rgba(0, 0, 0, 0.55),
          0 0 36px var(--pip-warm-glow),
          inset 0 1px 0 rgba(255, 255, 255, 0.14);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: visible;
      }
      .pip-orb .buddy {
        position: relative;
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background:
          radial-gradient(circle at 32% 26%, rgba(255, 255, 255, 0.1) 0%, transparent 44%),
          radial-gradient(circle at 50% 70%, var(--pip-warm-mist) 0%, transparent 50%),
          linear-gradient(160deg, var(--pip-light) 0%, var(--pip-mid) 55%, var(--pip-deep) 100%);
        border: 1.5px solid rgba(255, 255, 255, 0.11);
        box-shadow:
          inset 0 1px 0 rgba(255, 255, 255, 0.14),
          inset 0 -4px 10px rgba(0, 0, 0, 0.35);
        display: flex;
        align-items: center;
        justify-content: center;
        animation: buddy-breathe 3.4s ease-in-out infinite;
      }
      .pip-orb .ember {
        position: absolute;
        top: -8px;
        left: 50%;
        width: 14px;
        height: 16px;
        margin-left: -7px;
        border-radius: 50% 50% 50% 50% / 62% 62% 38% 38%;
        background: radial-gradient(circle at 42% 62%, #fff 0%, var(--pip-warm-soft) 34%, var(--pip-warm) 66%, var(--pip-warm-deep) 100%);
        box-shadow: 0 0 10px var(--pip-warm), 0 0 22px var(--pip-warm-glow);
        transform-origin: 50% 100%;
        animation: ember-flicker 1.7s ease-in-out infinite;
        z-index: 3;
      }
      .pip-orb .buddy-face {
        position: relative;
        width: 46px;
        height: 28px;
      }
      .pip-orb .eye {
        position: absolute;
        top: 2px;
        width: 18px;
        height: 16px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.96);
        border: 1.5px solid rgba(255, 255, 255, 0.2);
        overflow: hidden;
        box-shadow: inset 0 -2px 4px rgba(0, 0, 0, 0.2);
        transform-origin: 50% 50%;
        animation: eye-life 6.5s ease-in-out infinite;
      }
      @keyframes ember-flicker {
        0%, 100% { transform: translateY(0) scale(1) rotate(0deg); opacity: 0.9; }
        28% { transform: translateY(-3px) scale(1.12) rotate(-3deg); opacity: 1; }
        52% { transform: translateY(1px) scale(0.92) rotate(2deg); opacity: 0.82; }
        76% { transform: translateY(-1px) scale(1.05) rotate(-1deg); opacity: 0.96; }
      }
      @keyframes buddy-breathe {
        0%, 100% { transform: translateY(0) scale(1); }
        50% { transform: translateY(-4px) scale(1.04); }
      }
      @keyframes eye-life {
        0%, 38%, 42%, 80%, 84%, 88%, 92%, 100% { transform: scaleY(1); }
        40% { transform: scaleY(0.08); }
        82%, 90% { transform: scaleY(0.08); }
        86% { transform: scaleY(1); }
      }
      @keyframes pip-wave {
        0%, 100% { transform: rotate(0deg); }
        20% { transform: rotate(-10deg); }
        45% { transform: rotate(8deg); }
        70% { transform: rotate(-4deg); }
      }
      @keyframes pip-pop {
        0% { transform: scale(1); }
        35% { transform: scale(0.86, 1.12); }
        70% { transform: scale(1.06, 0.94); }
        100% { transform: scale(1); }
      }
      .pip-orb.is-greeting .buddy {
        animation: pip-wave 1.1s ease-in-out, buddy-breathe 3.4s ease-in-out 1.1s infinite;
      }
      .pip-orb.is-greeting .ember {
        animation: ember-flicker 0.9s ease-in-out infinite;
      }
      .pip-orb .eye.left { left: 0; }
      .pip-orb .eye.right { right: 0; }
      .pip-orb .iris {
        position: absolute;
        left: 2px;
        right: 2px;
        bottom: 2px;
        height: 11px;
        border-radius: 50%;
        background: radial-gradient(circle at 38% 30%, #f0e6d8 0%, var(--pip-warm-soft) 30%, var(--pip-warm) 65%, var(--pip-warm-deep) 100%);
      }
      .pip-orb .shine {
        position: absolute;
        top: 3px;
        left: 4px;
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.98);
        box-shadow: 3px 3px 0 rgba(255, 255, 255, 0.4);
      }
      .pip-orb .blush {
        position: absolute;
        bottom: 2px;
        width: 9px;
        height: 5px;
        border-radius: 50%;
        background: rgba(196, 160, 106, 0.22);
        filter: blur(0.5px);
      }
      .pip-orb .blush.left { left: -4px; }
      .pip-orb .blush.right { right: -4px; }
      .pip-orb .smile {
        position: absolute;
        bottom: -2px;
        left: 50%;
        width: 14px;
        height: 7px;
        margin-left: -7px;
        border-bottom: 2.5px solid rgba(196, 160, 106, 0.4);
        border-radius: 0 0 14px 14px;
      }
      .pip-orb.sm {
        width: 88px;
        height: 88px;
        margin-bottom: 12px;
      }
      .pip-orb.sm .buddy {
        width: 50px;
        height: 50px;
        animation: buddy-breathe 3.4s ease-in-out infinite;
      }
      .pip-orb.sm .ember {
        width: 10px;
        height: 11px;
        margin-left: -5px;
        top: -6px;
        animation: ember-flicker 1.7s ease-in-out infinite;
      }
      .pip-orb.sm .eye {
        width: 12px;
        height: 11px;
        animation: eye-life 6.5s ease-in-out infinite;
      }
      .pip-orb.sm .buddy-face { width: 32px; height: 20px; }
      .pip-orb.sm .iris { height: 7px; }
      .pip-orb.sm .shine { width: 3px; height: 3px; }
      .pip-orb.sm .blush { width: 6px; height: 3px; }
      .pip-orb.sm .smile { width: 10px; height: 5px; margin-left: -5px; border-bottom-width: 2px; }
      .pip-name {
        font-size: 96px;
        font-weight: 800;
        letter-spacing: -0.05em;
        line-height: 1;
      }
      .revolve {
        position: relative;
        margin-top: 28px;
        height: 64px;
        overflow: hidden;
        width: 100%;
      }
      .revolve-word {
        position: absolute;
        left: 0;
        top: 0;
        font-size: 52px;
        font-weight: 700;
        letter-spacing: -0.03em;
        color: #f4f5f7;
        opacity: 0;
        white-space: nowrap;
        text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
      }
      .revolve-word .surf {
        background: linear-gradient(90deg, #d9480f, #7048e8);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .face-slot {
        position: absolute;
        right: 56px;
        bottom: 56px;
        width: 280px;
        height: 280px;
        z-index: 12;
        border-radius: 50%;
        overflow: hidden;
        background: linear-gradient(
          145deg,
          rgba(255, 255, 255, 0.14),
          rgba(255, 255, 255, 0.04)
        );
        backdrop-filter: blur(20px) saturate(1.3);
        -webkit-backdrop-filter: blur(20px) saturate(1.3);
        border: 2px solid rgba(255, 255, 255, 0.28);
        box-shadow:
          0 16px 48px rgba(0, 0, 0, 0.45),
          inset 0 1px 0 rgba(255, 255, 255, 0.3),
          0 0 0 4px rgba(217, 72, 15, 0.35);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-align: center;
        padding: 24px;
      }
      .face-slot .face-label {
        font-size: 18px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(244, 245, 247, 0.7);
      }
      .face-slot .face-hint {
        font-size: 22px;
        font-weight: 600;
        color: #f4f5f7;
        line-height: 1.25;
      }
      .face-slot .face-sub {
        font-size: 16px;
        color: rgba(244, 245, 247, 0.45);
        font-family: "JetBrains Mono", monospace;
      }
      img.still-card {
        position: absolute;
        width: 1080px;
        height: 680px;
        object-fit: cover;
        object-position: center top;
        border-radius: 18px;
        border: 1.5px solid rgba(255, 255, 255, 0.28);
        box-shadow:
          0 28px 90px rgba(0, 0, 0, 0.55),
          inset 0 1px 0 rgba(255, 255, 255, 0.2);
        z-index: 1;
        background: #111;
      }
      #still-docs {
        left: 60px;
        top: 140px;
        z-index: 2;
      }
      #still-slack {
        left: 320px;
        top: 180px;
        z-index: 3;
      }
      #still-github {
        left: 140px;
        top: 260px;
        z-index: 4;
      }
      #still-desktop {
        left: 480px;
        top: 120px;
        z-index: 5;
      }
      #still-gmail {
        left: 260px;
        top: 300px;
        z-index: 6;
      }
      img.still-cursor {
        position: absolute;
        inset: 0;
        width: 1920px;
        height: 1080px;
        object-fit: cover;
        object-position: center top;
        z-index: 7;
      }
      .cmd {
        margin-top: 28px;
        display: inline-flex;
        align-items: center;
        gap: 14px;
        padding: 18px 26px;
        border-radius: 16px;
        background: rgba(0, 0, 0, 0.35);
        border: 1px solid rgba(255, 255, 255, 0.18);
        font-family: "JetBrains Mono", monospace;
        font-size: 28px;
      }
      .cmd .prompt {
        color: #0ca678;
      }
      .cmd .dim {
        color: rgba(244, 245, 247, 0.4);
      }
      .brand {
        font-size: 108px;
        font-weight: 800;
        letter-spacing: -0.05em;
      }
      .sub {
        margin-top: 12px;
        font-size: 32px;
        color: rgba(244, 245, 247, 0.7);
        font-weight: 400;
      }
      /* F1 — AI EVERYWHERE full-bleed */
      .f1-bg {
        position: absolute;
        inset: 0;
        width: 1920px;
        height: 1080px;
        object-fit: cover;
        object-position: center;
        z-index: 1;
        background: #000;
      }
      .f1-shade {
        position: absolute;
        inset: 0;
        z-index: 2;
        pointer-events: none;
        background:
          linear-gradient(90deg, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.15) 45%, rgba(0, 0, 0, 0.45) 100%),
          linear-gradient(180deg, rgba(0, 0, 0, 0.25) 0%, transparent 35%, rgba(0, 0, 0, 0.55) 100%);
      }
      .f1-copy {
        left: 72px;
        right: auto;
        top: auto;
        bottom: 96px;
        width: 980px;
        max-width: 980px;
        z-index: 10;
        background: linear-gradient(
          145deg,
          rgba(8, 10, 16, 0.78),
          rgba(8, 10, 16, 0.5)
        );
      }
      .f1-line1,
      .f1-line2 {
        display: block;
      }

      /* F2 — Harmony-style liquid glass scatter list */
      .scatter-list {
        position: absolute;
        right: 72px;
        top: 160px;
        width: 620px;
        z-index: 11;
        padding: 40px 44px 36px;
        background: linear-gradient(
          160deg,
          rgba(255, 255, 255, 0.14),
          rgba(255, 255, 255, 0.04)
        );
        backdrop-filter: blur(36px) saturate(1.5);
        -webkit-backdrop-filter: blur(36px) saturate(1.5);
        border: 1px solid rgba(255, 255, 255, 0.22);
        border-radius: 28px;
        box-shadow:
          0 24px 80px rgba(0, 0, 0, 0.45),
          inset 0 1px 0 rgba(255, 255, 255, 0.28);
      }
      .scatter-list::before {
        content: "";
        position: absolute;
        left: 22px;
        right: 22px;
        top: 1px;
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.55),
          transparent
        );
      }
      .scatter-head {
        font-size: 42px;
        font-weight: 400;
        letter-spacing: -0.03em;
        color: #fff;
        line-height: 1.15;
      }
      .scatter-sub {
        margin-top: 10px;
        font-size: 22px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.55);
      }
      .scatter-rule {
        margin: 28px 0 22px;
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.45) 20%,
          rgba(255, 255, 255, 0.45) 80%,
          transparent
        );
        box-shadow: 0 0 12px rgba(255, 255, 255, 0.25);
      }
      .scatter-section {
        font-size: 26px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.92);
        margin-bottom: 18px;
        letter-spacing: -0.02em;
      }
      .scatter-item {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        padding: 14px 4px;
        opacity: 0;
      }
      .scatter-item .mark {
        width: 22px;
        height: 22px;
        margin-top: 4px;
        flex-shrink: 0;
        position: relative;
      }
      .scatter-item .mark .dot {
        position: absolute;
        inset: 6px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.85);
      }
      .scatter-item .mark .spin {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 2px solid rgba(255, 255, 255, 0.25);
        border-top-color: #fff;
        opacity: 0;
      }
      .scatter-item .body {
        flex: 1;
        min-width: 0;
      }
      .scatter-item .title {
        font-size: 26px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.92);
        letter-spacing: -0.02em;
        line-height: 1.25;
      }
      .scatter-item .desc {
        margin-top: 6px;
        font-size: 18px;
        color: rgba(255, 255, 255, 0.48);
        line-height: 1.35;
        max-height: 0;
        overflow: hidden;
        opacity: 0;
      }
      .scatter-item .chev {
        flex-shrink: 0;
        margin-top: 6px;
        width: 18px;
        height: 18px;
        color: rgba(255, 255, 255, 0.45);
      }
      .scatter-item.more .title {
        color: rgba(255, 255, 255, 0.4);
        letter-spacing: 0.12em;
      }
      #f2.caption-bl {
        max-width: 520px;
        top: 72px;
      }
      /* Keep pile left of the glass list */
      #still-docs { left: 40px; }
      #still-slack { left: 220px; }
      #still-github { left: 80px; }
      #still-desktop { left: 300px; }
      #still-gmail { left: 160px; }
    </style>
