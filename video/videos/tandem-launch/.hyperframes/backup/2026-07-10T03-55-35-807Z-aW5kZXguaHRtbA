        left: 18px;
        right: 18px;
        top: 1px;
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.55),
          transparent
        );
      }
      .kicker {
        font-size: 22px;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(244, 245, 247, 0.85);
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 12px;
        text-shadow: 0 1px 8px rgba(0, 0, 0, 0.65);
      }
      .kicker .dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: #d9480f;
        box-shadow: 0 0 16px rgba(217, 72, 15, 0.65);
      }
      .display {
        font-size: 72px;
        font-weight: 700;
        line-height: 1.02;
        letter-spacing: -0.04em;
